generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  firstName String
  lastName  String
  phone     String?
  avatar    String?
  role      String   @default("PATIENT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor?
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  nameAr    String?
  address   String
  addressAr String?
  city      String?
  phone     String?
  whatsapp  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctors   DoctorBranch[]
  appointments Appointment[]
}

model Doctor {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty String
  specialtyAr String?
  isActive  Boolean  @default(true)
  branches  DoctorBranch[]
  appointments Appointment[]
}

model DoctorBranch {
  doctorId  String
  branchId  String
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  @@id([doctorId, branchId])
}

model Patient {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  phone           String
  email           String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?
  medicalHistory  String?
  allergies       String?
  emergencyContact String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  appointments    Appointment[]
  diagnoses       Diagnosis[]
}

model Appointment {
  id         String   @id @default(cuid())
  patientId  String
  doctorId   String
  branchId   String
  date       DateTime
  startTime  String
  endTime    String
  status     String   @default("PENDING")
  department String   @default("GENERAL_DENTISTRY")
  reason     String?
  notes      String?
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Diagnosis {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  diagnosis  String
  notes      String?
  createdAt  DateTime @default(now())
}

model Service {
  id         String   @id @default(cuid())
  name       String
  nameAr     String?
  department String
  price      Float?
  duration   Int?
  isActive   Boolean  @default(true)
}

model Bill {
  id             String   @id @default(cuid())
  patientId      String
  appointmentId  String?
  total          Float
  status         String   @default("PENDING")
  paidAt         DateTime?
  items          Json?
  createdAt      DateTime @default(now())
}

model Insurance {
  id        String   @id @default(cuid())
  nameEn    String
  nameAr    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
